##############################################
# Python project .gitignore
##############################################

# Environment & secrets (CRITICAL!)
azure.env
*.env
.env
*.key
*.pem

# Virtual environments
venv/
.venv/
ENV/
env/

# Python cache & compiled artifacts
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.dll
*.egg-info/
.eggs/
build/
dist/
*.pyc
*$py.class

# Packaging / distribution
*.whl
*.spec

# Jupyter
.ipynb_checkpoints/
# Allow training notebooks
!qwen_finetuning_server.ipynb

# Editors / IDE
.vscode/
.idea/
*.swp
*.swo
*.tmp
*~

# Logs & sqlite/db
*.log
*.sqlite
*.db-journal
*.db-wal
runs.db
logs/

# Generated outputs & large artifacts (keep source scripts)
/datasets/
/apriori_outputs/
/extractor_outputs/
/validation_reports/
/visuals/
/db_prepared/
artifacts/

# Fine-tuning artifacts (optional - comment out if you want to track)
# training_data/  # Now tracked for enhanced dataset
# hf_dataset/     # Now tracked for enhanced dataset
!training_data/all_training_examples_enhanced.json
!hf_dataset_enhanced/
checkpoints/
runs/
wandb/

# Seed file (comment out if you want versioning)
master_seed.txt

# Large CSVs (ignore all except curated ones)
*.csv
!generation_log.csv  # Keep generation log for audit
!README.md
!requirements.txt

# Test/temporary files
ds_TEST.csv
temp_*.csv
scratch_*.py
test_*.py

# Caches
.cache/
.mypy_cache/
.pytest_cache/
__pycache__/

# Coverage
.coverage
htmlcov/

# Misc OS
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# Performance profiles
*.profile

# Archive (keep structure but ignore contents if needed)
# archive/
