##############################################
# itemsety-qwen-finetuning .gitignore
# Last updated: 2026-04-07
##############################################

# ── Secrets & environment (CRITICAL — never commit!) ──
*.env
.env
*.key
*.pem

# ── Virtual environments ──
.venv/
venv/
ENV/
env/

# ── Python cache & compiled artifacts ──
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.dll
*.egg-info/
.eggs/
build/
dist/
*$py.class
*.whl
*.spec

# ── Jupyter ──
.ipynb_checkpoints/

# ── Editors / IDE ──
.vscode/
.idea/
*.code-workspace
*.swp
*.swo
*.tmp
*~

# ── Obsidian vault config (track content, ignore app settings) ──
obsidian-brain/.obsidian/

# ── Database & logs ──
*.log
*.sqlite
*.db-journal
*.db-wal
runs.db
logs/

# ── Pipeline artifacts (regenerable from pipeline.py) ──
artifacts/
visuals/

# ── Generated research data (template repo keeps code only) ──
data/datasets_v*/
data/eval_datasets_v*/
data/hf_dataset_v*/
data/sft_cot*.json
data/dpo_real*.json
data/*.report.json
!data/README.md

# ── Generated evaluation outputs ──
eval_results/*
!eval_results/README.md

# ── Training infrastructure (lives on GPU server) ──
checkpoints/
runs/
wandb/

# ── Large/local CSVs ──
*.csv
!README.md
!requirements.txt
real_datasets/

# ── Temporary / scratch files ──
temp_*.csv
scratch_*.py
ds_TEST.csv
master_seed.txt
run_eval.sh

# ── Caches ──
.cache/
.mypy_cache/
.pytest_cache/

# ── Coverage ──
.coverage
htmlcov/

# ── OS files ──
.DS_Store
Thumbs.db
Desktop.ini

# ── Claude Code metadata ──
.claude/

# ── Archive (old notebooks, eval outputs, zips — preserved, not active) ──
archive/

# ── Claude Code conversation exports ──
20[0-9][0-9]-[0-9][0-9]-[0-9][0-9]-[0-9]*.txt

# ── MkDocs build output ──
site/
